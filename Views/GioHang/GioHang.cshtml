@using System.Linq
@using HuynhNgocLen.SachOnline.Models
@model List<GioHang>
@{
    ViewBag.Title = "Giỏ hàng";
    Layout = "~/Views/Shared/_LayoutUser.cshtml";
    var coHang = Model != null && Model.Any();
}

<h1 class="h3 page-heading text-center mb-4">Giỏ hàng của bạn</h1>

@if (!coHang)
{
    <div class="card border-0 shadow-sm text-center py-5 px-3 mb-4">
        <div class="card-body">
            <i class="bi bi-cart-x text-secondary d-block mb-3" style="font-size: 3.5rem;"></i>
            <p class="text-secondary mb-4">Chưa có sản phẩm nào trong giỏ hàng.</p>
            <a href="@Url.Action("Index", "SachOnline")" class="btn btn-so-primary btn-lg px-4"><i class="bi bi-shop me-2"></i>Tiếp tục mua sắm</a>
        </div>
    </div>
}
else
{
<div class="table-responsive card border-0 shadow-sm">
    <table class="table table-hover align-middle mb-0">
        <thead class="table-light">
            <tr class="text-center small text-uppercase text-secondary">
                <th>Mã</th>
                <th class="text-start">Tên sách</th>
                <th>Ảnh</th>
                <th>Số lượng</th>
                <th>Đơn giá</th>
                <th>Thành tiền</th>
                <th>Chi tiết</th>
                <th>Xóa</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td class="text-center">@item.iMaSach</td>
                    <td>@item.sTenSach</td>
                    <td class="text-center">
                        <img src="@Url.Content("~/Images/" + item.sAnhBia)" alt="" class="rounded" style="width: 72px; height: 96px; object-fit: cover;" />
                    </td>
                    <td class="text-center" style="min-width: 140px;">
                        @using (Html.BeginForm("CapNhatGioHang", "GioHang", new { iMaSach = item.iMaSach }, FormMethod.Post, new { @class = "d-flex flex-column gap-2 align-items-center" }))
                        {
                            <input type="number" min="1" name="txtSoLuong" value="@item.iSoLuong" class="form-control form-control-sm text-center" style="width: 5rem;" />
                            <button type="submit" class="btn btn-sm btn-so-primary">Cập nhật</button>
                        }
                    </td>
                    <td class="text-end">@string.Format("{0:#,##0}", item.dDonGia) đ</td>
                    <td class="text-end fw-semibold">@string.Format("{0:#,##0}", item.dThanhTien) đ</td>
                    <td class="text-center">
                        <a class="btn btn-sm btn-outline-primary" href="@Url.Action("ChiTietSach", "SachOnline", new { id = item.iMaSach })">Chi tiết</a>
                    </td>
                    <td class="text-center">
                        <button type="button"
                                class="btn btn-sm btn-outline-danger"
                                data-bs-toggle="modal"
                                data-bs-target="#modalXoaMotSanPham"
                                data-delete-url="@Url.Action("XoaSPKhoiGioHang", "GioHang", new { iMaSach = item.iMaSach })">
                            Xóa
                        </button>
                    </td>
                </tr>
            }
        </tbody>
        <tfoot class="table-light">
            <tr>
                <td colspan="8" class="text-end py-3">
                    <span class="me-4 fw-semibold">Tổng số lượng: <strong class="text-primary">@string.Format("{0:#,##0}", ViewBag.TongSoLuong)</strong></span>
                    <span class="fw-semibold">Tổng tiền: <span class="price-tag fs-5">@string.Format("{0:#,##0}", ViewBag.TongTien) đ</span></span>
                </td>
            </tr>
        </tfoot>
    </table>
</div>

<div class="d-flex flex-column flex-md-row justify-content-between align-items-stretch align-items-md-center gap-3 mt-4">
    <button type="button" class="btn btn-outline-danger" data-bs-toggle="modal" data-bs-target="#modalXoaToanBoGio">
        Xóa toàn bộ giỏ
    </button>
    @Html.ActionLink("Đặt hàng", "DatHang", "GioHang", null, new { @class = "btn btn-so-primary btn-lg px-5" })
</div>

<div class="modal fade" id="modalXoaMotSanPham" tabindex="-1" aria-labelledby="modalXoaMotSanPhamLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow" style="border-radius: 8px;">
            <div class="modal-header border-bottom-0 pb-0">
                <h2 class="modal-title h5 fw-semibold" id="modalXoaMotSanPhamLabel">Xóa sản phẩm</h2>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Đóng"></button>
            </div>
            <div class="modal-body pt-2">
                Bạn có chắc muốn xóa sách này khỏi giỏ hàng?
            </div>
            <div class="modal-footer border-top-0 pt-0 gap-2">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Hủy</button>
                <a href="#" class="btn btn-danger" id="linkXoaMotSanPham">Xóa</a>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="modalXoaToanBoGio" tabindex="-1" aria-labelledby="modalXoaToanBoGioLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow" style="border-radius: 8px;">
            <div class="modal-header border-bottom-0 pb-0">
                <h2 class="modal-title h5 fw-semibold" id="modalXoaToanBoGioLabel">Xóa toàn bộ giỏ hàng</h2>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Đóng"></button>
            </div>
            <div class="modal-body pt-2">
                Xóa hết sản phẩm trong giỏ?
            </div>
            <div class="modal-footer border-top-0 pt-0 gap-2">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Hủy</button>
                <a href="@Url.Action("XoaGioHang", "GioHang")" class="btn btn-danger">Xóa hết</a>
            </div>
        </div>
    </div>
</div>

}

@section scripts
{
    <script>
        (function () {
            var modalEl = document.getElementById('modalXoaMotSanPham');
            if (!modalEl) return;
            modalEl.addEventListener('show.bs.modal', function (event) {
                var trigger = event.relatedTarget;
                var url = trigger && trigger.getAttribute('data-delete-url');
                var link = document.getElementById('linkXoaMotSanPham');
                if (link && url) link.setAttribute('href', url);
            });
        })();
    </script>
}
