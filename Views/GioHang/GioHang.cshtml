@using HuynhNgocLen.SachOnline.Models
@model List<GioHang>
@{
    ViewBag.Title = "Giỏ hàng";
    Layout = "~/Views/Shared/_LayoutUser.cshtml";
}

<h1 class="h3 page-heading text-center mb-4">Giỏ hàng của bạn</h1>

<div class="table-responsive card border-0 shadow-sm">
    <table class="table table-hover align-middle mb-0">
        <thead class="table-light">
            <tr class="text-center small text-uppercase text-secondary">
                <th>Mã</th>
                <th class="text-start">Tên sách</th>
                <th>Ảnh</th>
                <th>Số lượng</th>
                <th>Đơn giá</th>
                <th>Thành tiền</th>
                <th>Chi tiết</th>
                <th>Xóa</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td class="text-center">@item.iMaSach</td>
                    <td>@item.sTenSach</td>
                    <td class="text-center">
                        <img src="@Url.Content("~/Images/" + item.sAnhBia)" alt="" class="rounded" style="width: 72px; height: 96px; object-fit: cover;" />
                    </td>
                    <td class="text-center" style="min-width: 140px;">
                        @using (Html.BeginForm("CapNhatGioHang", "GioHang", new { iMaSach = item.iMaSach }, FormMethod.Post, new { @class = "d-flex flex-column gap-2 align-items-center" }))
                        {
                            <input type="number" min="1" name="txtSoLuong" value="@item.iSoLuong" class="form-control form-control-sm text-center" style="width: 5rem;" />
                            <button type="submit" class="btn btn-sm btn-so-primary">Cập nhật</button>
                        }
                    </td>
                    <td class="text-end">@string.Format("{0:#,##0}", item.dDonGia) đ</td>
                    <td class="text-end fw-semibold">@string.Format("{0:#,##0}", item.dThanhTien) đ</td>
                    <td class="text-center">
                        <a class="btn btn-sm btn-outline-primary" href="@Url.Action("ChiTietSach", "SachOnline", new { id = item.iMaSach })">Chi tiết</a>
                    </td>
                    <td class="text-center">
                        @Html.ActionLink("Xóa", "XoaSPKhoiGioHang", new { iMaSach = item.iMaSach }, new { @class = "btn btn-sm btn-outline-danger", onclick = "return confirm('Bạn có chắc muốn xóa?');" })
                    </td>
                </tr>
            }
        </tbody>
        <tfoot class="table-light">
            <tr>
                <td colspan="8" class="text-end py-3">
                    <span class="me-4 fw-semibold">Tổng số lượng: <strong class="text-primary">@string.Format("{0:#,##0}", ViewBag.TongSoLuong)</strong></span>
                    <span class="fw-semibold">Tổng tiền: <span class="price-tag fs-5">@string.Format("{0:#,##0}", ViewBag.TongTien) đ</span></span>
                </td>
            </tr>
        </tfoot>
    </table>
</div>

<div class="d-flex flex-column flex-md-row justify-content-between align-items-stretch align-items-md-center gap-3 mt-4">
    @Html.ActionLink("Xóa toàn bộ giỏ", "XoaGioHang", null, new { @class = "btn btn-outline-danger", onclick = "return confirm('Xóa hết sản phẩm trong giỏ?');" })
    @Html.ActionLink("Đặt hàng", "DatHang", "GioHang", null, new { @class = "btn btn-so-primary btn-lg px-5" })
</div>
