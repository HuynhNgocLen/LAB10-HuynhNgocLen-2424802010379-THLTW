@model HuynhNgocLen.SachOnline.Models.SACH
@using System.Collections.Generic
@using HuynhNgocLen.SachOnline.Models
@{
    ViewBag.Title = "Chi tiết sách";
    Layout = "~/Views/Shared/_LayoutUser.cshtml";
    var lienQuan = ViewBag.SachLienQuan as List<SACH> ?? new List<SACH>();
    var moTa = Model.MoTa ?? "";
}

<nav aria-label="breadcrumb" class="breadcrumb-so">
    <ol class="breadcrumb mb-3">
        <li class="breadcrumb-item"><a href="@Url.Action("Index", "SachOnline")">Trang chủ</a></li>
        <li class="breadcrumb-item active" aria-current="page">@Model.TenSach</li>
    </ol>
</nav>

<div class="row g-4">
    <div class="col-md-5 col-lg-4">
        <div class="card border-0 shadow-sm overflow-hidden">
            <img src="@Url.Content("~/Images/" + Model.AnhBia)" class="img-fluid w-100" alt="@Model.TenSach" style="object-fit: cover; max-height: 520px;" />
        </div>
    </div>
    <div class="col-md-7 col-lg-8">
        <h1 class="h3 page-heading">@Model.TenSach</h1>
        @if (Model.CHUDE != null)
        {
            <p class="text-secondary small mb-2"><i class="bi bi-tag"></i> Chủ đề: @Model.CHUDE.TenChuDe</p>
        }
        @if (Model.NHAXUATBAN != null)
        {
            <p class="text-secondary small mb-3"><i class="bi bi-building"></i> Nhà xuất bản: @Model.NHAXUATBAN.TenNXB</p>
        }
        <p class="mb-2"><strong>Ngày cập nhật:</strong> @Html.FormatValue(Model.NgayCapNhat, "{0:dd/MM/yyyy}")</p>
        <p class="price-tag fs-4 mb-4">@Html.FormatValue(Model.GiaBan, "{0:#,##0}") đ</p>

        <div class="d-flex flex-wrap gap-2 mb-4">
            <a href="@Url.Action("ThemGioHang", "GioHang", new { ms = Model.MaSach, url = Request.Url?.ToString() })" class="btn btn-so-primary btn-lg px-4">
                <i class="bi bi-cart-plus"></i> Thêm vào giỏ hàng
            </a>
            <a href="@Url.Action("Index", "SachOnline")" class="btn btn-outline-secondary btn-lg">Tiếp tục mua</a>
        </div>

        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white fw-semibold border-0 pt-3">Mô tả sách</div>
            <div class="card-body text-secondary" style="text-align: justify;">
                @if (string.IsNullOrWhiteSpace(moTa))
                {
                    <p class="mb-0 fst-italic">Chưa có mô tả cho cuốn sách này.</p>
                }
                else
                {
                    @Html.Raw(moTa.Replace("\n", "<br />"))
                }
            </div>
        </div>
    </div>
</div>

@if (lienQuan.Any())
{
    <hr class="my-5 opacity-25" />
    <h2 class="h4 page-heading mb-4">Sách cùng chủ đề</h2>
    <div class="row">
        @foreach (var s in lienQuan)
        {
            @Html.Partial("_SachCard", s)
        }
    </div>
}
