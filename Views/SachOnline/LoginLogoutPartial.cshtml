@using HuynhNgocLen.SachOnline.Models
@{
    Layout = null;
    KHACHHANG kh = Session["TaiKhoan"] as KHACHHANG;
}

@if (kh == null)
{
    <li class="nav-item dropdown">
        <a class="nav-link dropdown-toggle d-inline-flex align-items-center gap-1"
           href="#"
           id="storeAccountDropdown"
           role="button"
           data-bs-toggle="dropdown"
           aria-expanded="false"
           aria-haspopup="true">
            <i class="bi bi-person"></i> Tài khoản
        </a>
        <ul class="dropdown-menu dropdown-menu-end store-nav-account-menu" aria-labelledby="storeAccountDropdown">
            <li>
                <a class="dropdown-item" href="@Url.Action("DangKy", "User")">
                    <i class="bi bi-person-plus me-2"></i>Đăng ký
                </a>
            </li>
            <li>
                <a class="dropdown-item" href="@Url.Action("DangNhap", "User", new { url = Request.Url?.ToString() })">
                    <i class="bi bi-box-arrow-in-right me-2"></i>Đăng nhập
                </a>
            </li>
            <li><hr class="dropdown-divider" /></li>
            <li>
                <a class="dropdown-item" href="@Url.Action("Login", "Home", new { area = "Admin" })">
                    <i class="bi bi-shield-lock me-2"></i>Đăng nhập Admin
                </a>
            </li>
        </ul>
    </li>
}
else
{
    <li class="nav-item dropdown">
        <a class="nav-link dropdown-toggle d-inline-flex align-items-center gap-1"
           href="#"
           id="storeUserDropdown"
           role="button"
           data-bs-toggle="dropdown"
           aria-expanded="false"
           style="max-width: 14rem;"
           title="@kh.HoTen">
            <i class="bi bi-person-circle flex-shrink-0"></i>
            <span class="text-truncate">@kh.HoTen</span>
        </a>
        <ul class="dropdown-menu dropdown-menu-end store-nav-account-menu" aria-labelledby="storeUserDropdown">
            <li>
                <a class="dropdown-item" href="@Url.Action("DonHang", "User")">
                    <i class="bi bi-journal-text me-2"></i>Lịch sử đơn hàng
                </a>
            </li>
            <li><hr class="dropdown-divider" /></li>
            <li>
                <a class="dropdown-item store-dropdown-logout" href="@Url.Action("DangXuat", "User")">
                    <i class="bi bi-box-arrow-right me-2"></i>Đăng xuất
                </a>
            </li>
        </ul>
    </li>
}
