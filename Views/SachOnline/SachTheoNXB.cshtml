@using HuynhNgocLen.SachOnline.Models
@using PagedList.Mvc;
@model PagedList.PagedList<SACH>
@{
    ViewBag.Title = "Sách theo NXB";
    Layout = "~/Views/Shared/_LayoutUser.cshtml";
}

<nav aria-label="breadcrumb" class="breadcrumb-so">
    <ol class="breadcrumb mb-2">
        <li class="breadcrumb-item"><a href="@Url.Action("Index", "SachOnline")">Trang chủ</a></li>
        <li class="breadcrumb-item active" aria-current="page">@ViewBag.NXB</li>
    </ol>
</nav>

<h1 class="h3 page-heading text-center mb-4">Sách theo nhà xuất bản: @ViewBag.NXB</h1>

<div class="row">
    @if (Model != null && Model.Any())
    {
        foreach (var sach in Model)
        {
            @Html.Partial("_SachCard", sach)
        }
    }
    else
    {
        <div class="col-12">
            <div class="alert alert-info border-0 shadow-sm">Hiện chưa có sách nào thuộc nhà xuất bản này.</div>
        </div>
    }
</div>

<div class="d-flex flex-column align-items-center gap-2 mt-4">
    <span class="text-secondary small">
        Trang @(Model.PageCount < Model.PageNumber ? 0 : Model.PageNumber) / @Model.PageCount
    </span>
    @Html.PagedListPager(Model, page => Url.Action("SachTheoNXB", new { id = ViewBag.MaNXB, page = page }))
</div>

@section SachBanNhieu{
    @Html.Action("SachBanNhieuPartial", "SachOnline")
}
