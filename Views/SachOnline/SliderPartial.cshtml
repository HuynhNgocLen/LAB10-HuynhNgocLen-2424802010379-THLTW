<div class="carousel slide carousel-fade carousel-hero mb-4" id="carouselHero" data-bs-ride="carousel">
    <div class="carousel-indicators">
        <button type="button" data-bs-target="#carouselHero" data-bs-slide-to="0" class="active" aria-current="true" aria-label="Slide 1"></button>
        <button type="button" data-bs-target="#carouselHero" data-bs-slide-to="1" aria-label="Slide 2"></button>
        <button type="button" data-bs-target="#carouselHero" data-bs-slide-to="2" aria-label="Slide 3"></button>
        <button type="button" data-bs-target="#carouselHero" data-bs-slide-to="3" aria-label="Slide 4"></button>
        <button type="button" data-bs-target="#carouselHero" data-bs-slide-to="4" aria-label="Slide 5"></button>
        <button type="button" data-bs-target="#carouselHero" data-bs-slide-to="5" aria-label="Slide 6"></button>
    </div>
    <div class="carousel-inner">
        <div class="carousel-item active">
            <img class="d-block w-100" src="~/Images/Slider/01.jpg" alt="Banner 1" style="max-height: 320px; object-fit: cover;" />
            <div class="carousel-caption d-none d-md-block small">Ưu đãi sách mới</div>
        </div>
        <div class="carousel-item">
            <img class="d-block w-100" src="~/Images/Slider/02.jpg" alt="Banner 2" style="max-height: 320px; object-fit: cover;" />
            <div class="carousel-caption d-none d-md-block small">Giao nhanh toàn quốc</div>
        </div>
        <div class="carousel-item">
            <img class="d-block w-100" src="~/Images/Slider/03.jpg" alt="Banner 3" style="max-height: 320px; object-fit: cover;" />
            <div class="carousel-caption d-none d-md-block small">Đa dạng chủ đề</div>
        </div>
        <div class="carousel-item">
            <img class="d-block w-100" src="~/Images/Slider/04.jpg" alt="Banner 4" style="max-height: 320px; object-fit: cover;" />
            <div class="carousel-caption d-none d-md-block small">Sách bán chạy</div>
        </div>
        <div class="carousel-item">
            <img class="d-block w-100" src="~/Images/Slider/05.jpg" alt="Banner 5" style="max-height: 320px; object-fit: cover;" />
            <div class="carousel-caption d-none d-md-block small">NXB uy tín</div>
        </div>
        <div class="carousel-item">
            <img class="d-block w-100" src="~/Images/Slider/06.jpg" alt="Banner 6" style="max-height: 320px; object-fit: cover;" />
            <div class="carousel-caption d-none d-md-block small">Mua sắm an toàn</div>
        </div>
    </div>
    <button class="carousel-control-prev" type="button" data-bs-target="#carouselHero" data-bs-slide="prev">
        <span class="carousel-control-prev-icon" aria-hidden="true"></span>
        <span class="visually-hidden">Trước</span>
    </button>
    <button class="carousel-control-next" type="button" data-bs-target="#carouselHero" data-bs-slide="next">
        <span class="carousel-control-next-icon" aria-hidden="true"></span>
        <span class="visually-hidden">Sau</span>
    </button>
</div>
