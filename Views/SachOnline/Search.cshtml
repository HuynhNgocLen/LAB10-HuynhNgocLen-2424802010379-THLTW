@using PagedList.Mvc;
@model PagedList.PagedList<HuynhNgocLen.SachOnline.Models.SACH>
@{
    ViewBag.Title = "Tìm kiếm";
    Layout = "~/Views/Shared/_LayoutUser.cshtml";
    var so = ViewBag.SoKetQua != null ? (int)ViewBag.SoKetQua : Model.TotalItemCount;
}

<div class="mb-4">
    <h1 class="h3 page-heading">Kết quả tìm kiếm</h1>
    <p class="text-secondary mb-0">
        Từ khóa: <strong class="text-body">@ViewBag.TuKhoa</strong>
        — Tìm thấy <strong class="price-tag">@so</strong> cuốn sách
    </p>
</div>

@if (Model.Count == 0)
{
    <div class="alert alert-warning border-0 shadow-sm">
        <i class="bi bi-info-circle me-2"></i>Không tìm thấy sách nào phù hợp. Thử từ khóa ngắn hơn hoặc kiểm tra chính tả.
    </div>
}
else
{
    <div class="row">
        @foreach (var sach in Model)
        {
            @Html.Partial("_SachCard", sach)
        }
    </div>

    <div class="d-flex flex-column align-items-center gap-2 mt-4">
        <span class="text-secondary small">
            Trang @(Model.PageCount < Model.PageNumber ? 0 : Model.PageNumber) / @Model.PageCount
        </span>
        @Html.PagedListPager(Model, page => Url.Action("Search", new { data = ViewBag.TuKhoa, page = page }))
    </div>
}
