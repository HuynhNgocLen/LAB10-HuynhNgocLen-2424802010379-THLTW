@using PagedList.Mvc;
@model PagedList.PagedList<HuynhNgocLen.SachOnline.Models.SACH>
@{
    ViewBag.Title = "Trang chủ";
    Layout = "~/Views/Shared/_LayoutUser.cshtml";
}

<div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-2 mb-4">
    <h1 class="h3 page-heading mb-0">Sách mới</h1>
    <span class="text-secondary small">Cập nhật theo ngày phát hành</span>
</div>

<div class="row">
    @foreach (var sach in Model)
    {
        @Html.Partial("_SachCard", sach)
    }
</div>

<div class="d-flex flex-column align-items-center gap-2 mt-4">
    <span class="text-secondary small">
        Trang @(Model.PageCount < Model.PageNumber ? 0 : Model.PageNumber) / @Model.PageCount
    </span>
    @Html.PagedListPager(Model, page => Url.Action("Index", "SachOnline", new { page = page }))
</div>

@section SachBanNhieu{
    @Html.Action("SachBanNhieuPartial", "SachOnline")
}
