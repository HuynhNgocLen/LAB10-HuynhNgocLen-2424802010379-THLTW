@using HuynhNgocLen.SachOnline.Security
@{
    ViewBag.Title = "Gửi lại mã xác thực email";
    Layout = "~/Views/Shared/_LayoutUser.cshtml";
}

<div class="so-auth-card py-3">
    <h1 class="h3 page-heading text-center mb-4">Gửi lại mã xác thực email</h1>
    <p class="text-muted text-center small mb-3">
        Nhập <strong>tên đăng nhập</strong> hoặc <strong>email</strong> đã dùng khi đăng ký. Hệ thống sẽ gửi mã <strong>@OtpService.CodeLength số</strong> tới email của tài khoản để bạn kích hoạt.
    </p>

    @if (TempData["Info"] != null)
    {
        <div class="alert alert-success border-0 shadow-sm">@TempData["Info"]</div>
    }

    @if (ViewBag.ThongBao != null)
    {
        <div class="alert alert-warning border-0 shadow-sm">@ViewBag.ThongBao</div>
    }

    <div class="card border-0 shadow-sm">
        <div class="card-body p-4">
            @using (Html.BeginForm("GuiLaiXacThucEmail", "User", FormMethod.Post, new { @class = "needs-validation" }))
            {
                @Html.AntiForgeryToken()
                <div class="mb-3">
                    <label class="form-label" for="TenDNHoacEmail">Tên đăng nhập hoặc email</label>
                    <input type="text" name="TenDNHoacEmail" id="TenDNHoacEmail" class="form-control" value="@Request.Form["TenDNHoacEmail"]" placeholder="Ví dụ: nguyenvana hoặc email@example.com" autocomplete="username" required />
                    <span class="text-danger small">@ViewData["Err1"]</span>
                </div>
                <div class="d-grid gap-2">
                    <button type="submit" class="btn btn-so-primary btn-lg">Gửi mã xác thực</button>
                </div>
            }
        </div>
    </div>

    <p class="text-center mt-3 small">
        <a href="@Url.Action("DangNhap", "User")">Quay lại đăng nhập</a>
        &nbsp;·&nbsp;
        <a href="@Url.Action("DangKy", "User")">Đăng ký tài khoản mới</a>
    </p>
</div>