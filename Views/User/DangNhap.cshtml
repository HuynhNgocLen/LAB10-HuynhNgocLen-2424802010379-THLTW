@model HuynhNgocLen.SachOnline.Models.KHACHHANG
@{
    ViewBag.Title = "Đăng nhập";
    Layout = "~/Views/Shared/_LayoutUser.cshtml";
}

<div class="so-auth-card py-3">
    <h1 class="h3 page-heading text-center mb-4">Đăng nhập</h1>

    @if (TempData["Info"] != null)
    {
        <div class="alert alert-success border-0 shadow-sm">@TempData["Info"]</div>
    }

    @if (ViewBag.ThongBao != null)
    {
        <div class="alert alert-danger border-0 shadow-sm">@ViewBag.ThongBao</div>
    }

    <div class="card border-0 shadow-sm">
        <div class="card-body p-4">
            @using (Html.BeginForm("DangNhap", "User", new { url = ViewBag.Url }, FormMethod.Post, new { @class = "needs-validation" }))
            {
                @Html.ValidationSummary(true, "", new { @class = "text-danger small mb-3" })
                <div class="mb-3">
                    <label class="form-label">Tên đăng nhập</label>
                    @Html.TextBox("TenDN", null, new { @class = "form-control", @placeholder = "Nhập tên đăng nhập", autocomplete = "username", required = "required" })
                    <span class="text-danger small">@ViewData["Err1"]</span>
                </div>
                <div class="mb-4">
                    <label class="form-label">Mật khẩu</label>
                    <div class="input-group">
                        @Html.Password("MatKhau", null, new { @class = "form-control", @placeholder = "Nhập mật khẩu", autocomplete = "current-password", required = "required", id = "MatKhau" })
                        <button class="btn btn-outline-secondary" type="button" id="togglePassword" onclick="togglePasswordVisibility()" tabindex="-1">
                            <i class="bi bi-eye" id="eyeIcon"></i>
                        </button>
                    </div>
                    <span class="text-danger small">@ViewData["Err2"]</span>
                </div>
                <div class="d-grid gap-2">
                    <button type="submit" class="btn btn-so-primary btn-lg">Đăng nhập</button>
                    <a href="@Url.Action("GuiLaiXacThucEmail", "User")" class="btn btn-link small">Chưa xác thực email? Gửi lại mã</a>
                    <a href="@Url.Action("QuenMatKhau", "User")" class="btn btn-link small">Quên mật khẩu?</a>
                    <a href="@Url.Action("DangKy", "User")" class="btn btn-link">Chưa có tài khoản? Đăng ký ngay</a>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts
{
    <script>
        function togglePasswordVisibility() {
            const input = document.getElementById('MatKhau');
            const icon = document.getElementById('eyeIcon');

            if (input.type === 'password') {
                input.type = 'text';
                icon.classList.replace('bi-eye', 'bi-eye-slash');
            } else {
                input.type = 'password';
                icon.classList.replace('bi-eye-slash', 'bi-eye');
            }
        }
    </script>
}