@using System.Web
@{
    var cartToastMsg = TempData["CartToast"] as string;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewBag.Title - SachOnline</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link href="~/Content/PagedList.css" rel="stylesheet" />
    <link href="~/Content/Site.css" rel="stylesheet" />
    <link href="~/Content/sachonline-store.css" rel="stylesheet" />
</head>
<body class="store-body d-flex flex-column min-vh-100">
    @Html.Action("NavPartial", "SachOnline")

    <div class="store-shell flex-grow-1">
        <div class="container store-main">
            @Html.Action("SliderPartial", "SachOnline")

            <div class="row g-4">
                <aside class="col-lg-3">
                    <div class="store-sidebar sticky-lg-top" style="top: 5.5rem;">
                        @Html.Action("ChuDePartial", "SachOnline")
                        <div class="mt-3">
                            @Html.Action("NhaXuatBanPartial", "SachOnline")
                        </div>
                    </div>
                </aside>

                <div class="col-lg-9">
                    @RenderBody()
                    <hr class="my-4 opacity-25" />
                    @RenderSection("SachBanNhieu", required: false)
                </div>
            </div>
        </div>
    </div>

    @Html.Action("FooterPartial", "SachOnline")

    <button type="button" id="btnBackTop" class="btn-back-top" aria-label="Lên đầu trang">
        <i class="bi bi-arrow-up"></i>
    </button>

    <div class="toast-container position-fixed bottom-0 end-0 p-3" style="z-index: 1090">
        <div id="cartToast" class="toast text-bg-dark border-0" role="alert" aria-live="polite" aria-atomic="true">
            <div class="d-flex">
                <div class="toast-body">
                    <i class="bi bi-cart-check text-warning me-2"></i>
                    <span id="cartToastMsg">Đã cập nhật giỏ hàng.</span>
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Đóng"></button>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        (function () {
            var btn = document.getElementById('btnBackTop');
            if (btn) {
                window.addEventListener('scroll', function () {
                    btn.classList.toggle('visible', window.scrollY > 400);
                });
                btn.addEventListener('click', function () { window.scrollTo({ top: 0, behavior: 'smooth' }); });
            }
            @if (!string.IsNullOrEmpty(cartToastMsg))
            {
                <text>
                document.addEventListener('DOMContentLoaded', function () {
                    var el = document.getElementById('cartToast');
                    var msg = document.getElementById('cartToastMsg');
                    if (msg) msg.textContent = @Html.Raw(HttpUtility.JavaScriptStringEncode(cartToastMsg));
                    if (el && typeof bootstrap !== 'undefined') {
                        var t = new bootstrap.Toast(el, { delay: 3500 });
                        t.show();
                    }
                });
                </text>
            }
        })();
    </script>
    @RenderSection("scripts", required: false)
</body>
</html>
