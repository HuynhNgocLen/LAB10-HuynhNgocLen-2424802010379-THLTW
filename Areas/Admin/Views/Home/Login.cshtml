@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Đăng nhập Admin</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        :root {
            --wf-text: #080808;
            --wf-blue: #146ef5;
            --wf-blue-hover: #0055d4;
            --wf-border: #d8d8d8;
            --wf-shadow: rgba(0,0,0,0) 0px 84px 24px, rgba(0,0,0,0.01) 0px 54px 22px,
                rgba(0,0,0,0.04) 0px 30px 18px, rgba(0,0,0,0.08) 0px 13px 13px, rgba(0,0,0,0.09) 0px 3px 7px;
        }
        body {
            min-height: 100vh;
            margin: 0;
            font-family: 'Inter', 'Segoe UI', system-ui, sans-serif;
            background: #fafafa;
            color: var(--wf-text);
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 24px;
        }

        .login-wrapper {
            width: 100%;
            max-width: 960px;
            background: #fff;
            border: 1px solid var(--wf-border);
            border-radius: 8px;
            box-shadow: var(--wf-shadow);
            overflow: hidden;
            display: grid;
            grid-template-columns: 1.1fr 1fr;
        }

        .login-aside {
            padding: 44px 40px;
            background: #146ef5;
            color: #fff;
        }

        .login-aside .brand {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            font-weight: 600;
            letter-spacing: -0.02em;
        }

        .login-aside .brand i {
            width: 40px;
            height: 40px;
            border-radius: 4px;
            background: rgba(255,255,255,0.2);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 1.1rem;
        }

        .feature-list {
            margin-top: 28px;
            padding-left: 0;
            list-style: none;
            font-size: 15px;
            line-height: 1.4;
        }

        .feature-list li {
            margin-bottom: 12px;
        }

        .login-form-area {
            padding: 44px 36px;
        }

        .login-title {
            color: var(--wf-text);
            font-weight: 600;
            font-size: 24px;
            margin-bottom: 4px;
        }

        .form-control {
            border-radius: 4px;
            min-height: 44px;
            border: 1px solid var(--wf-border);
        }

        .form-control:focus {
            border-color: var(--wf-blue);
            box-shadow: 0 0 0 1px var(--wf-blue);
        }

        .btn-login {
            border-radius: 4px;
            padding: 12px 16px;
            font-weight: 500;
            background: var(--wf-blue);
            border: none;
        }
        .btn-login:hover {
            background: var(--wf-blue-hover);
        }

        @@media (max-width: 900px) {
            .login-wrapper {
                grid-template-columns: 1fr;
            }

            .login-aside {
                display: none;
            }
        }
    </style>
</head>
<body>
    <div class="login-wrapper">
        <div class="login-aside">
            <div class="brand">
                <i class="bi bi-book-half"></i>
                <span>SachOnline Admin</span>
            </div>
            <h3 class="mt-4 mb-2 fw-bold">Quản trị hệ thống bán sách</h3>
            <p class="mb-0 opacity-75">Theo dõi đơn hàng, doanh thu và vận hành cửa hàng hiệu quả hơn.</p>
            <ul class="feature-list">
                <li><i class="bi bi-check-circle me-2"></i>Dashboard tổng quan trực quan</li>
                <li><i class="bi bi-check-circle me-2"></i>Quản lý sách, chủ đề, nhà xuất bản</li>
                <li><i class="bi bi-check-circle me-2"></i>Theo dõi khách hàng và đơn hàng</li>
            </ul>
        </div>

        <div class="login-form-area">
            <h3 class="login-title">Đăng nhập quản trị</h3>
            <p class="text-muted mb-4">Vui lòng nhập thông tin để truy cập trang admin.</p>

            @if (ViewBag.ThongBao != null)
            {
                <div class="alert alert-danger py-2 mb-3">
                    <i class="bi bi-exclamation-triangle me-1"></i>@ViewBag.ThongBao
                </div>
            }

            <form action="~/Admin/Home/Login" method="post">
                <div class="mb-3">
                    <label for="UserName" class="form-label">Tên đăng nhập</label>
                    <input type="text" id="UserName" name="UserName" class="form-control" required autocomplete="off">
                </div>
                <div class="mb-3">
                    <label for="Password" class="form-label">Mật khẩu</label>
                    <input type="password" id="Password" name="Password" class="form-control" required>
                </div>
                <button type="submit" class="btn btn-primary btn-login w-100">
                    <i class="bi bi-box-arrow-in-right me-1"></i> Đăng nhập
                </button>
            </form>

            <div class="mt-3 text-center">
                <a href="@Url.Action("Index", "SachOnline", new { area = "" })" class="text-decoration-none">Quay về trang chủ</a>
            </div>
        </div>
    </div>
</body>
</html>