<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>@ViewBag.Title - SachOnline Admin</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="~/Content/Site.css" rel="stylesheet" />
    <link href="~/Content/sachonline-admin.css" rel="stylesheet" />
</head>
<body class="admin-wf">

    <!-- Sidebar -->
    <div class="sidebar">
        <div class="p-4 border-bottom">
            <a href="@Url.Action("Dashboard", "Home")" class="text-decoration-none">
                <h4 class="navbar-brand mb-0">
                    <i class="bi bi-book"></i> SachOnline
                </h4>
                <small class="text-muted d-block">Quản trị viên</small>
            </a>
        </div>

        @{
            var ad = Session["Admin"] as HuynhNgocLen.SachOnline.Models.ADMIN;
            int quyen = ad != null ? (ad.Quyen ?? 0) : 0;
        }

        <ul class="nav flex-column pt-3">
            <li class="nav-item">
                <a class="nav-link @(ViewBag.ActiveMenu == "Dashboard" ? "active" : "")"
                   href="@Url.Action("Dashboard","Home")">
                    <i class="bi bi-house-door me-2"></i> Dashboard
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(ViewBag.ActiveMenu == "Sach" ? "active" : "")"
                   href="@Url.Action("Index","Sach")">
                    <i class="bi bi-book-half me-2"></i> Quản lý Sách
                </a>
            </li>

            @if (quyen == 1)
            {
                <li class="nav-item">
                    <a class="nav-link @(ViewBag.ActiveMenu == "ChuDe" ? "active" : "")"
                       href="@Url.Action("Index","ChuDe")">
                        <i class="bi bi-tags me-2"></i> Quản lý Chủ đề
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewBag.ActiveMenu == "NhaXuatBan" ? "active" : "")"
                       href="@Url.Action("Index","NhaXuatBan")">
                        <i class="bi bi-building me-2"></i> Quản lý Nhà xuất bản
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewBag.ActiveMenu == "KhachHang" ? "active" : "")"
                       href="@Url.Action("Index","KhachHang")">
                        <i class="bi bi-people me-2"></i> Quản lý Khách hàng
                    </a>
                </li>
            }

            <li class="nav-item">
                <a class="nav-link @(ViewBag.ActiveMenu == "DonHang" ? "active" : "")"
                   href="@Url.Action("Index","DonHang")">
                    <i class="bi bi-receipt me-2"></i> Quản lý Đơn hàng
                </a>
            </li>
        </ul>

        <div class="position-absolute bottom-0 w-100 p-4 border-top">
            <a href="@Url.Action("Logout","Home")" class="btn btn-outline-danger w-100">
                <i class="bi bi-box-arrow-right"></i> Đăng xuất
            </a>
        </div>
    </div>

    <!-- Top Navbar -->
    <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom fixed-top admin-topbar">
        <div class="container-fluid">
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarContent">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                            <i class="bi bi-person-circle"></i> Admin
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li><a class="dropdown-item" href="#">Hồ sơ</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item text-danger" href="@Url.Action("Logout","Home", new { area = "Admin" })">Đăng xuất</a></li>
                        </ul>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <div class="main-content pt-5 mt-4">
        <div class="container-fluid">
            @if (TempData["ThongBaoAdmin"] != null)
            {
                <div class="alert alert-warning alert-dismissible fade show" role="alert">
                    @TempData["ThongBaoAdmin"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Đóng"></button>
                </div>
            }
            @RenderBody()
        </div>
    </div>

    <!-- Modal xác nhận xóa (Admin) -->
    <div class="modal fade" id="adminDeleteModal" tabindex="-1" aria-labelledby="adminDeleteModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow">
                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title fw-semibold" id="adminDeleteModalLabel">
                        <i class="bi bi-exclamation-triangle text-danger me-1"></i> Xác nhận xóa
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Đóng"></button>
                </div>
                <div class="modal-body pt-2">
                    <p class="mb-0">Bạn có chắc muốn xóa <strong id="adminDeleteItemName"></strong>?</p>
                    <p class="text-danger small mb-0 mt-2">Thao tác này không thể hoàn tác.</p>
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" form="adminDeleteForm" class="btn btn-danger">
                        <i class="bi bi-trash"></i> Xóa
                    </button>
                </div>
            </div>
        </div>
    </div>
    <form id="adminDeleteForm" method="post" action="" style="display:none;">
        @Html.AntiForgeryToken()
    </form>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
    <script>
        (function () {
            var modalEl = document.getElementById('adminDeleteModal');
            var formEl = document.getElementById('adminDeleteForm');
            if (!modalEl || !formEl) return;
            modalEl.addEventListener('show.bs.modal', function (event) {
                var btn = event.relatedTarget;
                if (!btn) return;
                var url = btn.getAttribute('data-delete-url');
                var name = btn.getAttribute('data-item-name');
                if (url) formEl.setAttribute('action', url);
                var label = document.getElementById('adminDeleteItemName');
                if (label) label.textContent = (name && name.length) ? name : 'mục này';
            });
        })();
    </script>

    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/bootstrap")
    @RenderSection("scripts", required: false)
</body>
</html>
