@model IEnumerable<HuynhNgocLen.SachOnline.Models.DONDATHANG>

@{
    ViewBag.Title = "Quản lý đơn hàng";
    ViewBag.ActiveMenu = "DonHang";
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-dark">Quản lý đơn hàng</h2>
    </div>

    <div class="card border-0 shadow-sm rounded-3">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4">Mã đơn</th>
                            <th>Khách hàng</th>
                            <th>Ngày đặt</th>
                            <th class="text-center">Trạng thái</th>
                            <th class="text-end pe-4">Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-medium">#@item.MaDonHang</td>
                                <td>@item.KHACHHANG.HoTen</td>
                                <td>@item.NgayDat.ToString()</td>
                                <td class="text-center">
                                    @if (item.TinhTrangGiaoHang == 1)
                                    {
                                        <span class="badge bg-success">Đã giao</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning text-dark">Chưa giao</span>
                                    }
                                </td>
                                <td class="text-end pe-4">
                                    <div class="btn-group">
                                        <a href="@Url.Action("Details", "DonHang", new { id = item.MaDonHang })"
                                           class="btn btn-outline-info btn-sm px-3 rounded-2 me-2">
                                            <i class="bi bi-eye"></i> Chi tiết
                                        </a>

                                        <a href="@Url.Action("Edit", "DonHang", new { id = item.MaDonHang })"
                                           class="btn btn-outline-primary btn-sm px-3 rounded-2 me-2">
                                            <i class="bi bi-pencil"></i> Cập nhật
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>