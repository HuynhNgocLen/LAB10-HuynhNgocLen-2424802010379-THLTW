@model HuynhNgocLen.SachOnline.Models.DONDATHANG

@{
    ViewBag.Title = "Cập nhật Đơn hàng";
    ViewBag.ActiveMenu = "DonHang";
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="container-fluid pt-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="@Url.Action("Index", "DonHang")">Quản lý đơn hàng</a></li>
            <li class="breadcrumb-item active" aria-current="page">Cập nhật #@Model.MaDonHang</li>
        </ol>
    </nav>

    <div class="card shadow mb-4">
        <div class="card-header py-3 d-flex justify-content-between align-items-center bg-primary text-white">
            <h5 class="m-0 font-weight-bold">
                <i class="bi bi-pencil-square"></i> CẬP NHẬT ĐƠN HÀNG #@Model.MaDonHang
            </h5>
        </div>
        <div class="card-body">
            @using (Html.BeginForm("Edit", "DonHang", FormMethod.Post))
            {
                @Html.AntiForgeryToken()
                @Html.HiddenFor(model => model.MaDonHang)

                <div class="row justify-content-center">
                    <div class="col-md-8">

                        <div class="mb-4">
                            <label class="form-label fw-bold"><i class="bi bi-truck"></i> Tình trạng giao hàng</label>
                            <select name="TinhTrangGiaoHang" class="form-select form-select-lg">
                                <option value="0" @(Model.TinhTrangGiaoHang == 0 ? "selected" : "")>Mới đặt / Chờ duyệt</option>
                                <option value="1" @(Model.TinhTrangGiaoHang == 1 ? "selected" : "")>Chờ xác thực thanh toán (BANK)</option>
                                <option value="2" @(Model.TinhTrangGiaoHang == 2 ? "selected" : "")>Đang xử lý / Đóng gói</option>
                                <option value="3" @(Model.TinhTrangGiaoHang == 3 ? "selected" : "")>Đã giao hàng thành công</option>
                                <option value="4" @(Model.TinhTrangGiaoHang == 4 ? "selected" : "")>Đã hủy đơn</option>
                            </select>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold"><i class="bi bi-wallet2"></i> Trạng thái thanh toán</label>
                            <div class="form-check form-switch p-3 border rounded bg-light">
                                @Html.CheckBoxFor(model => model.DaThanhToan, new { @class = "form-check-input ms-0", @id = "DaThanhToan" })
                                <label class="form-check-label ms-2" for="DaThanhToan">Đã thanh toán / Đã nhận tiền</label>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold"><i class="bi bi-calendar-event"></i> Ngày giao dự kiến/thực tế</label>
                            <input type="date" name="Ngaygiao" class="form-control form-control-lg"
                                   value="@(Model.NgayGiao.HasValue ? Model.NgayGiao.Value.ToString("yyyy-MM-dd") : "")" />
                            <small class="text-muted">Lưu ý: Kiểm tra kỹ ngày trước khi lưu.</small>
                        </div>

                        <hr />

                        <div class="d-flex gap-2 justify-content-end">
                            <a href="@Url.Action("Index", "DonHang")" class="btn btn-outline-secondary px-4">
                                <i class="bi bi-arrow-left"></i> Quay lại
                            </a>
                            <button type="submit" class="btn btn-primary px-4 fw-bold">
                                <i class="bi bi-save"></i> Lưu thay đổi
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<style>
    .breadcrumb a {
        color: var(--primary-color, #0d6efd);
    }

    .breadcrumb a:hover {
        color: #0b5ed7;
    }

    .card-header.bg-primary {
        background-color: var(--primary-color, #0d6efd) !important;
    }

    .btn-primary {
        background-color: var(--primary-color, #0d6efd);
        border-color: var(--primary-color, #0d6efd);
    }

    .btn-primary:hover,
    .btn-primary:focus {
        background-color: #0b5ed7;
        border-color: #0a58ca;
    }

    .card {
        border-radius: 12px;
        overflow: hidden;
    }

    .form-select:focus,
    .form-control:focus {
        border-color: var(--primary-color, #0d6efd);
        box-shadow: 0 0 0 0.2rem rgba(13, 110, 253, 0.2);
    }

    .form-select-lg, .form-control-lg {
        font-size: 1rem;
        border-radius: 8px;
    }

    .btn {
        border-radius: 8px;
        transition: all 0.3s;
    }

        .btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 8px rgba(0,0,0,0.1);
        }
</style>