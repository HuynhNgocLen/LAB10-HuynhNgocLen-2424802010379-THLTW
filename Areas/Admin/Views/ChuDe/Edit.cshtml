@model HuynhNgocLen.SachOnline.Models.CHUDE
@{
    ViewBag.Title = "Sửa chủ đề";
    ViewBag.ActiveMenu = "ChuDe";
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";
}

<style>
    .edit-page {
        max-width: 720px;
        margin: 24px auto;
        padding: 0 12px;
    }

    .edit-panel {
        background: #ffffff;
        border: 1px solid #e5e7eb;
        border-radius: 8px;
    }

    .edit-panel-header {
        padding: 16px 20px;
        border-bottom: 1px solid #e5e7eb;
    }

    .edit-panel-header h4 {
        margin: 0;
        font-size: 20px;
        font-weight: 600;
        color: #111827;
    }

    .edit-panel-header p {
        margin: 4px 0 0;
        color: #6b7280;
        font-size: 14px;
    }

    .edit-panel-body {
        padding: 20px;
    }

    .form-group {
        margin-bottom: 16px;
    }

    .control-label {
        display: inline-block;
        margin-bottom: 6px;
        font-weight: 600;
        color: #374151;
    }

    .form-control {
        width: 100%;
        border-radius: 6px;
        border: 1px solid #d1d5db;
        box-shadow: none;
    }

    .form-control:focus {
        border-color: #9ca3af;
        box-shadow: none;
    }

    .text-danger {
        font-size: 13px;
        margin-top: 4px;
    }

    .action-row {
        display: flex;
        gap: 10px;
        margin-top: 20px;
    }

    .btn-primary {
        background-color: #1f2937;
        border-color: #1f2937;
    }

    .btn-primary:hover,
    .btn-primary:focus {
        background-color: #111827;
        border-color: #111827;
    }

    .btn-default {
        border: 1px solid #d1d5db;
        color: #374151;
        background: #fff;
    }
</style>

<div class="edit-page">
    <div class="edit-panel">
        <div class="edit-panel-header">
            <h4>Sửa Chủ Đề</h4>
            <p>Cập nhật thông tin chủ đề.</p>
        </div>
        <div class="edit-panel-body">
            @using (Html.BeginForm("Edit", "ChuDe", FormMethod.Post))
            {
                @Html.AntiForgeryToken()
                @Html.ValidationSummary(true, "", new { @class = "text-danger" })
                @Html.HiddenFor(model => model.MaCD)

                <div class="form-group">
                    <label class="control-label">Tên chủ đề</label>
                    @Html.EditorFor(model => model.TenChuDe, new { htmlAttributes = new { @class = "form-control", @required = "required", @placeholder = "Nhập tên chủ đề" } })
                    @Html.ValidationMessageFor(model => model.TenChuDe, "", new { @class = "text-danger" })
                </div>

                <div class="action-row">
                    <button type="submit" class="btn btn-primary">Lưu thay đổi</button>
                    <a href="@Url.Action("Index", "ChuDe")" class="btn btn-default">Quay lại danh sách</a>
                </div>
            }
        </div>
    </div>
</div>
