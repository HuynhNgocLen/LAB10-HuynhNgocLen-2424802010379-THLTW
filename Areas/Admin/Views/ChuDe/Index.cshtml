@model PagedList.IPagedList<HuynhNgocLen.SachOnline.Models.CHUDE>
@using PagedList.Mvc

@{
    ViewBag.Title = "Quản lý Chủ đề";
    ViewBag.ActiveMenu = "ChuDe";
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";
}

<link href="~/Content/PagedList.css" rel="stylesheet" />

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-dark fw-semibold">Quản lý Chủ đề</h2>
        <a href="@Url.Action("Create", "ChuDe")" class="btn btn-primary shadow-sm">
            <i class="bi bi-plus-lg"></i> Thêm chủ đề mới
        </a>
    </div>

    @using (Html.BeginForm("Index", "ChuDe", FormMethod.Get, new { @class = "mb-3" }))
    {
        <div class="input-group" style="max-width:400px;">
            @Html.TextBox("tuKhoa", ViewBag.TuKhoa as string, new { @class = "form-control border-end-0", placeholder = "Tìm theo tên chủ đề..." })
            <button type="submit" class="btn btn-white bg-white border border-start-0 text-primary">
                <i class="bi bi-search"></i> Tìm kiếm
            </button>
            <a href="@Url.Action("Index")" class="btn btn-light border">Xóa lọc</a>
        </div>
    }

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Mã Chủ Đề</th>
                            <th>Tên Chủ Đề</th>
                            <th class="text-end pe-4">Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="fw-medium">@item.MaCD</td>
                                <td class="fw-medium">@item.TenChuDe</td>
                                <td class="text-end pe-4">
                                    <div class="btn-group">
                                        <a href="@Url.Action("Edit", "ChuDe", new { id = item.MaCD })"
                                           class="btn btn-outline-primary btn-sm px-3 rounded-2 me-2">
                                            <i class="bi bi-pencil"></i> Sửa
                                        </a>
                                        <button type="button"
                                                class="btn btn-outline-danger btn-sm px-3 rounded-2"
                                                data-bs-toggle="modal"
                                                data-bs-target="#adminDeleteModal"
                                                data-delete-url="@Url.Action("Delete", "ChuDe", new { area = "Admin", id = item.MaCD })"
                                                data-item-name="@System.Web.HttpUtility.HtmlAttributeEncode(item.TenChuDe)">
                                            <i class="bi bi-trash"></i> Xóa
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="mt-3 text-center">
        <p class="text-muted">
            Trang @Model.PageNumber / @Model.PageCount
            &nbsp;|&nbsp;
            Tổng: @Model.TotalItemCount chủ đề
        </p>
        @Html.PagedListPager(Model, page => Url.Action("Index", new { page, tuKhoa = ViewBag.TuKhoa }),
            new PagedListRenderOptions
            {
                LiElementClasses = new[] { "page-item" },
                DisplayLinkToFirstPage = PagedListDisplayMode.Always,
                DisplayLinkToLastPage = PagedListDisplayMode.Always,
                DisplayLinkToPreviousPage = PagedListDisplayMode.Always,
                DisplayLinkToNextPage = PagedListDisplayMode.Always,
                MaximumPageNumbersToDisplay = 5
            })
    </div>
</div>
