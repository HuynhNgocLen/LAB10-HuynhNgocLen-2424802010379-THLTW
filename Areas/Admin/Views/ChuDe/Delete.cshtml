@model HuynhNgocLen.SachOnline.Models.CHUDE
@{
    ViewBag.Title = "Xóa chủ đề";
    ViewBag.ActiveMenu = "ChuDe";
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="container-fluid py-4">
    <div class="row justify-content-center">
        <div class="col-lg-6 col-md-8">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white border-0 py-3">
                    <h4 class="mb-0 text-danger">Xác nhận xóa chủ đề</h4>
                </div>
                <div class="card-body">
                    @Html.ValidationSummary(true, "", new { @class = "alert alert-danger" })

                    <div class="alert alert-warning d-flex align-items-start" role="alert">
                        <i class="bi bi-exclamation-triangle-fill me-2 mt-1"></i>
                        <div>
                            <strong>Thao tác này không thể hoàn tác.</strong>
                            <div>Bạn có chắc chắn muốn xóa chủ đề này không?</div>
                        </div>
                    </div>

                    <dl class="row mb-4 fs-6">
                        <dt class="col-sm-4">Mã chủ đề</dt>
                        <dd class="col-sm-8">@Model.MaCD</dd>

                        <dt class="col-sm-4">Tên chủ đề</dt>
                        <dd class="col-sm-8 fw-semibold text-danger">@Model.TenChuDe</dd>
                    </dl>

                    @using (Html.BeginForm("Delete", "ChuDe", new { id = Model.MaCD }, FormMethod.Post))
                    {
                        @Html.AntiForgeryToken()
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-danger">Xóa</button>
                            <a href="@Url.Action("Index", "ChuDe")" class="btn btn-default">Quay lại danh sách</a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
