@model HuynhNgocLen.SachOnline.Models.KHACHHANG
@{
    ViewBag.Title = "Xác Nhận Xóa Khách Hàng";
    ViewBag.ActivePage = "KhachHang";
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap');

    .kh-del-wrapper {
        font-family: 'Inter', sans-serif;
        padding: 2rem 1.5rem;
        min-height: 100vh;
        background: #f8fafc;
    }

    /* Breadcrumb */
    .kh-breadcrumb {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.8rem;
        color: #94a3b8;
        margin-bottom: 1.5rem;
    }

        .kh-breadcrumb a {
            color: #64748b;
            text-decoration: none;
        }

            .kh-breadcrumb a:hover {
                color: #ef4444;
            }

        .kh-breadcrumb span {
            color: #cbd5e1;
        }

    /* Card */
    .kh-del-card {
        max-width: 500px;
        margin: 0 auto;
        background: #fff;
        border-radius: 16px;
        border: 1px solid #e2e8f0;
        box-shadow: 0 1px 4px rgba(0,0,0,0.06), 0 4px 20px rgba(239,68,68,0.06);
        overflow: hidden;
    }

    /* Warning banner */
    .kh-del-banner {
        background: #fff5f5;
        border-bottom: 1px solid #fecaca;
        padding: 1.5rem 2rem;
        display: flex;
        align-items: flex-start;
        gap: 1rem;
    }

    .kh-del-icon {
        width: 44px;
        height: 44px;
        background: #fee2e2;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

        .kh-del-icon svg {
            width: 22px;
            height: 22px;
            stroke: #ef4444;
            fill: none;
            stroke-width: 2;
            stroke-linecap: round;
            stroke-linejoin: round;
        }

    .kh-del-banner-text h5 {
        font-size: 1rem;
        font-weight: 600;
        color: #b91c1c;
        margin: 0 0 0.2rem;
    }

    .kh-del-banner-text p {
        font-size: 0.8rem;
        color: #ef4444;
        margin: 0;
        line-height: 1.5;
    }

    /* Info body */
    .kh-del-body {
        padding: 1.6rem 2rem 1.8rem;
    }

    .kh-info-label {
        font-size: 0.7rem;
        font-weight: 600;
        color: #94a3b8;
        text-transform: uppercase;
        letter-spacing: 0.07em;
        margin-bottom: 0.85rem;
    }

    .kh-info-list {
        list-style: none;
        padding: 0;
        margin: 0 0 1.4rem;
        display: flex;
        flex-direction: column;
        gap: 0.7rem;
    }

        .kh-info-list li {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            font-size: 0.88rem;
            color: #334155;
        }

            .kh-info-list li svg {
                width: 15px;
                height: 15px;
                stroke: #94a3b8;
                fill: none;
                stroke-width: 2;
                stroke-linecap: round;
                stroke-linejoin: round;
                flex-shrink: 0;
            }

            .kh-info-list li strong {
                font-weight: 600;
                color: #0f172a;
                margin-right: 0.25rem;
            }

            .kh-info-list li span.empty {
                color: #cbd5e1;
                font-style: italic;
                font-size: 0.82rem;
            }

    /* Error box */
    .kh-error-box {
        background: #fff5f5;
        border: 1px solid #fca5a5;
        border-radius: 8px;
        padding: 0.75rem 1rem;
        display: flex;
        align-items: flex-start;
        gap: 0.6rem;
        margin-bottom: 1.2rem;
    }

        .kh-error-box svg {
            width: 15px;
            height: 15px;
            stroke: #ef4444;
            fill: none;
            stroke-width: 2;
            stroke-linecap: round;
            stroke-linejoin: round;
            flex-shrink: 0;
            margin-top: 1px;
        }

        .kh-error-box span {
            font-size: 0.82rem;
            color: #b91c1c;
            line-height: 1.5;
        }

    /* Divider */
    .kh-divider {
        height: 1px;
        background: #f1f5f9;
        margin: 0 0 1.2rem;
    }

    /* Buttons */
    .kh-del-actions {
        display: flex;
        gap: 0.6rem;
        align-items: center;
    }

    .kh-btn-danger {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        padding: 0.58rem 1.3rem;
        background: #ef4444;
        color: #fff;
        border: none;
        border-radius: 9px;
        font-size: 0.86rem;
        font-weight: 600;
        font-family: 'Inter', sans-serif;
        cursor: pointer;
        transition: background 0.15s, box-shadow 0.15s, transform 0.12s;
        box-shadow: 0 2px 8px rgba(239,68,68,0.25);
    }

        .kh-btn-danger:hover {
            background: #dc2626;
            box-shadow: 0 4px 14px rgba(239,68,68,0.35);
            transform: translateY(-1px);
        }

        .kh-btn-danger svg {
            width: 15px;
            height: 15px;
            stroke: #fff;
            fill: none;
            stroke-width: 2.2;
            stroke-linecap: round;
            stroke-linejoin: round;
        }

    .kh-btn-ghost {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        padding: 0.58rem 1.15rem;
        background: transparent;
        color: #64748b;
        border: 1.5px solid #e2e8f0;
        border-radius: 9px;
        font-size: 0.86rem;
        font-weight: 500;
        font-family: 'Inter', sans-serif;
        text-decoration: none;
        transition: background 0.15s, border-color 0.15s, color 0.15s, transform 0.12s;
    }

        .kh-btn-ghost:hover {
            background: #f8fafc;
            border-color: #cbd5e1;
            color: #334155;
            transform: translateY(-1px);
        }

        .kh-btn-ghost svg {
            width: 14px;
            height: 14px;
            stroke: currentColor;
            fill: none;
            stroke-width: 2.2;
            stroke-linecap: round;
            stroke-linejoin: round;
        }

    @@media (max-width: 480px) {
        .kh-del-body {
            padding: 1.3rem 1.2rem 1.5rem;
        }

        .kh-del-banner {
            padding: 1.2rem;
        }

        .kh-del-actions {
            flex-direction: column;
            align-items: stretch;
        }

        .kh-btn-danger, .kh-btn-ghost {
            justify-content: center;
        }
    }
</style>

<div class="kh-del-wrapper">

    <nav class="kh-breadcrumb">
        <a href="@Url.Action("Index", "KhachHang")">Khách hàng</a>
        <span>›</span>
        <span>Xác nhận xóa</span>
    </nav>

    <div class="kh-del-card">

        <div class="kh-del-banner">
            <div class="kh-del-icon">
                <svg viewBox="0 0 24 24">
                    <polyline points="3 6 5 6 21 6" />
                    <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6" />
                    <path d="M10 11v6" />
                    <path d="M14 11v6" />
                    <path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2" />
                </svg>
            </div>
            <div class="kh-del-banner-text">
                <h5>Xác nhận xóa khách hàng</h5>
                <p>Hành động này không thể hoàn tác. Dữ liệu sẽ bị xóa vĩnh viễn khỏi hệ thống.</p>
            </div>
        </div>

        <div class="kh-del-body">

            @if (ViewBag.ThongBao != null)
            {
                <div class="kh-error-box">
                    <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" /><line x1="12" y1="8" x2="12" y2="12" /><line x1="12" y1="16" x2="12.01" y2="16" /></svg>
                    <span>@ViewBag.ThongBao</span>
                </div>
            }

            <p class="kh-info-label">Thông tin khách hàng sẽ bị xóa</p>

            <ul class="kh-info-list">
                <li>
                    <svg viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" /><circle cx="12" cy="7" r="4" /></svg>
                    <span><strong>@Model.HoTen</strong></span>
                    <span style="color:#94a3b8;font-size:0.8rem;">(Mã KH: @Model.MaKH)</span>
                </li>
                <li>
                    <svg viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" /><circle cx="12" cy="7" r="4" /></svg>
                    <span><strong>Tài khoản:</strong> @Model.TaiKhoan</span>
                </li>
                <li>
                    <svg viewBox="0 0 24 24"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" /><polyline points="22,6 12,13 2,6" /></svg>
                    @if (!string.IsNullOrEmpty(Model.Email))
                    {
                        <span>@Model.Email</span>
                    }
                    else
                    {
                        <span class="empty">Chưa cập nhật</span>
                    }
                </li>
                <li>
                    <svg viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.18h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.78a16 16 0 0 0 5.61 5.61l1.71-1.71a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7a2 2 0 0 1 1.72 2.03z" /></svg>
                    @if (!string.IsNullOrEmpty(Model.DienThoai))
                    {
                        <span>@Model.DienThoai</span>
                    }
                    else
                    {
                        <span class="empty">Chưa cập nhật</span>
                    }
                </li>
            </ul>

            <div class="kh-divider"></div>

            <div class="kh-del-actions">
                @using (Html.BeginForm("Delete", "KhachHang", new { id = Model.MaKH }, FormMethod.Post))
                {
                    @Html.AntiForgeryToken()
                    <button type="submit" class="kh-btn-danger">
                        <svg viewBox="0 0 24 24">
                            <polyline points="3 6 5 6 21 6" />
                            <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6" />
                            <path d="M10 11v6" />
                            <path d="M14 11v6" />
                            <path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2" />
                        </svg>
                        Xác nhận xóa
                    </button>
                }
                <a href="@Url.Action("Index", "KhachHang")" class="kh-btn-ghost">
                    <svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6" /></svg>
                    Hủy bỏ
                </a>
            </div>

        </div>
    </div>
</div>
