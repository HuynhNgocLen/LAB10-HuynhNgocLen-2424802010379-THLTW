@model PagedList.IPagedList<HuynhNgocLen.SachOnline.Models.KHACHHANG>
@using PagedList.Mvc

@{
    ViewBag.Title = "Quản lý Khách Hàng";
    ViewBag.ActiveMenu = "KhachHang";
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";
}

<link href="~/Content/PagedList.css" rel="stylesheet" />

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-dark fw-semibold">Quản lý Khách Hàng</h2>
    </div>

    @using (Html.BeginForm("Index", "KhachHang", FormMethod.Get, new { @class = "mb-3" }))
    {
        <div class="input-group" style="max-width:400px;">
            @Html.TextBox("tuKhoa", ViewBag.TuKhoa as string, new { @class = "form-control border-end-0", placeholder = "Tìm theo tên khách hàng..." })
            <button type="submit" class="btn btn-white bg-white border border-start-0 text-primary">
                <i class="bi bi-search"></i> Tìm kiếm
            </button>
            <a href="@Url.Action("Index")" class="btn btn-light border">Xóa lọc</a>
        </div>
    }

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-3">ID</th>
                            <th>Tên Khách Hàng</th>
                            <th>Email</th>
                            <th>Số Điện Thoại</th>
                            <th>Địa Chỉ</th>
                            <th class="text-end pe-4">Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-3 fw-medium">@item.MaKH</td>
                                <td class="fw-medium">@item.HoTen</td>
                                <td>@item.Email</td>
                                <td>@item.DienThoai</td>
                                <td style="max-width:200px;" class="text-truncate">@item.DiaChi</td>
                                <td class="text-end pe-4">
                                    <a href="@Url.Action("Edit", "KhachHang", new { id = item.MaKH })"
                                       class="btn btn-outline-primary btn-sm me-1">
                                        <i class="bi bi-pencil"></i> Sửa
                                    </a>
                                    <button type="button"
                                            class="btn btn-outline-danger btn-sm"
                                            data-bs-toggle="modal"
                                            data-bs-target="#adminDeleteModal"
                                            data-delete-url="@Url.Action("Delete", "KhachHang", new { area = "Admin", id = item.MaKH })"
                                            data-item-name="@System.Web.HttpUtility.HtmlAttributeEncode(item.HoTen)">
                                        <i class="bi bi-trash"></i> Xóa
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="mt-3 text-center">
        <p class="text-muted">
            Trang @(Model.PageCount < Model.PageNumber ? 0 : Model.PageNumber) / @Model.PageCount
            &nbsp;|&nbsp;
            Tổng: @Model.TotalItemCount khách hàng
        </p>
        @Html.PagedListPager(Model, page => Url.Action("Index", new { page, tuKhoa = ViewBag.TuKhoa }),
            new PagedListRenderOptions
            {
                LiElementClasses = new[] { "page-item" },
                DisplayLinkToFirstPage = PagedListDisplayMode.Always,
                DisplayLinkToLastPage = PagedListDisplayMode.Always,
                DisplayLinkToPreviousPage = PagedListDisplayMode.Always,
                DisplayLinkToNextPage = PagedListDisplayMode.Always,
                MaximumPageNumbersToDisplay = 5
            })
    </div>
</div>
