@model IEnumerable<HuynhNgocLen.SachOnline.Models.NHAXUATBAN>
@{
    ViewBag.Title = "Quản lý Nhà Xuất Bản";
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-dark fw-semibold">Quản lý Sách</h2>
        <a href="@Url.Action("Create", "NhaXuatBan")" class="btn btn-primary shadow-sm">
            <i class="bi bi-plus-lg"></i> Thêm mới nhà xuất bản
        </a>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">Tên nhà xuất bản</th>
                            <th class="text-end pe-4">Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-medium">@item.TenNXB</td>
                                <td class="text-end pe-4">
                                    <a href="@Url.Action("Edit", "NhaXuatBan", new { id = item.MaNXB })"
                                       class="btn btn-outline-primary btn-sm me-1">
                                        <i class="bi bi-pencil"></i> Sửa
                                    </a>
                                    <a href="@Url.Action("Delete", "NhaXuatBan", new { id = item.MaNXB })"
                                       class="btn btn-outline-danger btn-sm">
                                        <i class="bi bi-trash"></i> Xóa
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
    </div>
