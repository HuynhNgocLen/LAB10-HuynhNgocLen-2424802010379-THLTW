@model HuynhNgocLen.SachOnline.Models.NHAXUATBAN
@{
    ViewBag.Title = "Sửa Nhà Xuất Bản";
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";
}

<style>
    .edit-page {
        max-width: 760px;
        margin: 24px auto;
        padding: 0 12px;
    }

    .edit-panel {
        background: #ffffff;
        border: 1px solid #e5e7eb;
        border-radius: 8px;
        overflow: hidden;
    }

    .edit-panel-header {
        padding: 16px 20px;
        background: var(--primary-color, #0d6efd);
        border-bottom: none;
    }

    .edit-panel-header h4 {
        margin: 0;
        font-size: 20px;
        font-weight: 600;
        color: #ffffff;
    }

    .edit-panel-header p {
        margin: 4px 0 0;
        color: rgba(255, 255, 255, 0.9);
        font-size: 14px;
    }

    .edit-panel-body {
        padding: 20px;
    }

    .form-group {
        margin-bottom: 16px;
    }

    .control-label {
        display: inline-block;
        margin-bottom: 6px;
        font-weight: 600;
        color: #374151;
    }

    .form-control {
        width: 100%;
        border-radius: 6px;
        border: 1px solid #d1d5db;
        box-shadow: none;
    }

    .form-control:focus {
        border-color: var(--primary-color, #0d6efd);
        box-shadow: 0 0 0 0.2rem rgba(13, 110, 253, 0.2);
    }

    .text-danger {
        font-size: 13px;
        margin-top: 4px;
    }

    .action-row {
        display: flex;
        gap: 10px;
        margin-top: 20px;
    }

    .btn-primary {
        background-color: var(--primary-color, #0d6efd);
        border-color: var(--primary-color, #0d6efd);
    }

    .btn-primary:hover,
    .btn-primary:focus {
        background-color: #0b5ed7;
        border-color: #0a58ca;
    }

    .btn-default {
        border: 1px solid #d1d5db;
        color: #374151;
        background: #fff;
    }
</style>

<div class="edit-page">
    <div class="edit-panel">
        <div class="edit-panel-header">
            <h4>Sửa Nhà Xuất Bản</h4>
            <p>Cập nhật thông tin nhà xuất bản.</p>
        </div>

        <div class="edit-panel-body">
            @using (Html.BeginForm("Edit", "NhaXuatBan", FormMethod.Post))
            {
                @Html.AntiForgeryToken()
                @Html.ValidationSummary(true, "", new { @class = "text-danger" })
                @Html.HiddenFor(model => model.MaNXB)

                <div class="form-group">
                    <label class="control-label">Tên NXB</label>
                    @Html.EditorFor(model => model.TenNXB, new { htmlAttributes = new { @class = "form-control", @required = "required", @placeholder = "Nhập tên nhà xuất bản" } })
                    @Html.ValidationMessageFor(model => model.TenNXB, "", new { @class = "text-danger" })
                </div>

                <div class="form-group">
                    <label class="control-label">Địa chỉ</label>
                    @Html.EditorFor(model => model.DiaChi, new { htmlAttributes = new { @class = "form-control", @placeholder = "Nhập địa chỉ" } })
                    @Html.ValidationMessageFor(model => model.DiaChi, "", new { @class = "text-danger" })
                </div>

                <div class="form-group">
                    <label class="control-label">Điện thoại</label>
                    @Html.EditorFor(model => model.DienThoai, new { htmlAttributes = new { @class = "form-control", @placeholder = "Nhập số điện thoại" } })
                    @Html.ValidationMessageFor(model => model.DienThoai, "", new { @class = "text-danger" })
                </div>

                <div class="action-row">
                    <button type="submit" class="btn btn-primary">Lưu thay đổi</button>
                    <a href="@Url.Action("Index", "NhaXuatBan")" class="btn btn-default">Quay lại danh sách</a>
                </div>
            }
        </div>
    </div>
</div>
